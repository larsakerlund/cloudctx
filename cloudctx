#!/usr/bin/env python3
"""cloudctx — per-window Azure/AWS CLI context isolation.

A single, zero-dependency CLI. The sourced `cloudctx` shell function (which
shadows this binary) eval's the output of `cloudctx _env <name>` to mutate the
parent shell, and runs `cloudctx _decorate <name>` for iTerm2 visuals.
Everything else runs here.

Sections below: paths, TOML registry, color helpers, env emission,
decorate emission, commands, argparse dispatch.
"""
import argparse
import base64
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

__version__ = "1.2.0"

ESC = "\x1b"
BEL = "\x07"

NAME_RE = re.compile(r"^[A-Za-z0-9_-]+$")

# Optional fields accepted by `new`, mapped to their registry keys.
AZURE_FIELDS = ["azure_tenant", "azure_subscription"]
AWS_FIELDS = ["aws_sso_start_url", "aws_sso_region", "aws_account_id",
              "aws_role", "aws_profile"]


# --------------------------------------------------------------------------
# Paths
# --------------------------------------------------------------------------
def REGISTRY_ROOT() -> Path:
    """Root of the context store. Overridable via $CLOUDCTX_HOME (for tests)."""
    return Path(os.environ.get("CLOUDCTX_HOME", str(Path.home() / ".cloudctx")))


def registry_path() -> Path:
    return REGISTRY_ROOT() / "contexts.toml"


def context_dir(name: str) -> Path:
    # Defense in depth: never turn an unsafe name into a path component.
    if not NAME_RE.match(name):
        raise ValueError(f"unsafe context name {name!r}")
    return REGISTRY_ROOT() / name


def azure_dir(name: str) -> Path:
    return context_dir(name) / "azure"


def aws_config(name: str) -> Path:
    return context_dir(name) / "aws" / "config"


def aws_credentials(name: str) -> Path:
    return context_dir(name) / "aws" / "credentials"


def die(msg: str) -> int:
    print(f"cloudctx: error: {msg}", file=sys.stderr)
    return 1


def _chmod(path, mode) -> None:
    """chmod that warns rather than silently swallowing failure — these modes
    protect a credential store, so a silent miss must not go unnoticed."""
    try:
        os.chmod(path, mode)
    except OSError as e:
        print(f"cloudctx: warning: could not set {oct(mode)} on {path}: {e}",
              file=sys.stderr)


# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------
def cmd_new(args) -> int:
    name = args.name
    if not NAME_RE.match(name):
        return die(f"invalid context name {name!r} (use letters, digits, '-', '_')")
    registry = load_registry()
    if name in registry:
        return die(f"context {name!r} already exists")
    if args.color:
        try:
            hex_to_rgb255(args.color)
        except ValueError:
            return die(f"invalid color {args.color!r} (use #rgb or #rrggbb)")

    azure_dir(name).mkdir(parents=True, exist_ok=True)
    (context_dir(name) / "aws").mkdir(parents=True, exist_ok=True)
    # Lock down the whole per-context credential store (tokens land here).
    for d in (context_dir(name), azure_dir(name), context_dir(name) / "aws"):
        _chmod(d, 0o700)

    entry = {}
    if args.display:
        entry["display"] = args.display
    if args.color:
        entry["color"] = args.color
    for field in AZURE_FIELDS + AWS_FIELDS:
        value = getattr(args, field, None)
        if value:
            entry[field] = value
    entry.setdefault("display", name)
    registry[name] = entry
    save_registry(registry)
    print(f"created context {name!r} at {context_dir(name)}")

    if not getattr(args, "no_profiles", False):
        try:
            write_profiles()
        except OSError:
            pass  # e.g. no iTerm2 dir on a non-mac box; not fatal

    if not args.no_login:
        return cmd_login(argparse.Namespace(
            name=name, dry_run=False, device_code=getattr(args, "device_code", False)))
    print(f"next: authenticate with  cloudctx login {name}")
    return 0


def cmd_delete(args) -> int:
    name = args.name
    registry = load_registry()
    if name not in registry:
        return die(f"unknown context {name!r}")
    store = context_dir(name)
    if os.environ.get("CLOUDCTX_CONTEXT") == name:
        print(f"cloudctx: warning: {name!r} is active in this shell — run "
              f"`cloudctx clear` after deleting.", file=sys.stderr)
    if not args.force:
        what = "registry entry" if args.keep_store else \
            f"registry entry AND credential store {store} (tokens are wiped)"
        try:
            reply = input(f"delete context {name!r} — {what}? [y/N] ")
        except EOFError:
            reply = ""
        if reply.strip().lower() not in ("y", "yes"):
            print("aborted — nothing deleted")
            return 1
    del registry[name]
    save_registry(registry)
    if not args.keep_store and store.exists():
        shutil.rmtree(store)
    try:
        write_profiles()
    except OSError:
        pass  # same tolerance as cmd_new: no iTerm2 dir on a non-mac box
    kept = f" (store kept at {store})" if args.keep_store else ""
    print(f"deleted context {name!r}{kept}")
    return 0


def cmd_list(args) -> int:
    registry = load_registry()
    if not registry:
        print("no contexts. Create one with: cloudctx new <name>")
        return 0
    active = os.environ.get("CLOUDCTX_CONTEXT")
    if not getattr(args, "verbose", False):
        for name in sorted(registry):
            mark = "*" if name == active else " "
            print(f"{mark} {name}")
        return 0
    rows = []
    for name in sorted(registry):
        entry = registry[name]
        rows.append((
            "*" if name == active else " ",
            name,
            entry.get("display", ""),
            entry.get("azure_subscription") or entry.get("azure_tenant", ""),
            entry.get("aws_profile", ""),
        ))
    headers = (" ", "NAME", "DISPLAY", "AZURE", "AWS_PROFILE")
    widths = [max(len(r[i]) for r in rows + [headers]) for i in range(5)]
    for row in [headers] + rows:
        print("  ".join(cell.ljust(w) for cell, w in zip(row, widths)).rstrip())
    return 0


def cmd_show(args) -> int:
    registry = load_registry()
    name = args.name
    if name not in registry:
        return die(f"unknown context {name!r}")
    entry = registry[name]
    print(f"[{name}]")
    for key in sorted(entry):
        print(f"{key} = {entry[key]}")
    print()
    az = azure_dir(name)
    print(f"azure store:     {az}  {'(exists)' if az.is_dir() else '(missing)'}")
    cfg, cred = aws_config(name), aws_credentials(name)
    print(f"aws config:      {cfg}  {'(exists)' if cfg.is_file() else '(missing)'}")
    print(f"aws credentials: {cred}  {'(exists)' if cred.is_file() else '(missing)'}")
    return 0


def cmd_names(args) -> int:
    for name in sorted(load_registry()):
        print(name)
    return 0


# --------------------------------------------------------------------------
# Registry (TOML)
#
# tomllib is 3.11+ and read-only; on the 3.9 build machine it is absent, so we
# fall back to a tiny parser for our restricted schema (flat [name] tables with
# key = "value" string pairs). There is no stdlib TOML *writer* on any version,
# so _dump_toml is always hand-rolled.
# --------------------------------------------------------------------------
try:
    import tomllib as _tomllib
except ModuleNotFoundError:  # Python < 3.11
    _tomllib = None


def _parse_toml(text: str) -> dict:
    """Minimal TOML reader for our schema: [table] headers and key = "string"."""
    result: dict = {}
    table = None
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and "]" in line:
            # trim at the closing bracket so a hand-edited `[name]  # comment`
            # header parses the same way tomllib does, instead of being dropped.
            table = line[1:line.index("]")].strip()
            result.setdefault(table, {})
            continue
        if "=" not in line or table is None:
            continue
        key, _, rhs = line.partition("=")
        result[table][key.strip()] = _parse_value(rhs.strip())
    return result


def _parse_value(rhs: str) -> str:
    """Parse the right-hand side of `key = value`. Quoted strings honor \\" and
    \\\\ escapes; a trailing ` # comment` outside the quotes is ignored."""
    if rhs.startswith('"'):
        out = []
        i = 1
        while i < len(rhs):
            ch = rhs[i]
            if ch == "\\" and i + 1 < len(rhs):
                nxt = rhs[i + 1]
                if nxt == "u" and i + 5 < len(rhs):
                    try:
                        out.append(chr(int(rhs[i + 2:i + 6], 16)))
                        i += 6
                        continue
                    except ValueError:
                        pass  # not 4 hex digits: fall through to literal 'u'
                out.append({'"': '"', "\\": "\\", "n": "\n", "t": "\t",
                            "r": "\r"}.get(nxt, nxt))
                i += 2
                continue
            if ch == '"':
                break
            out.append(ch)
            i += 1
        return "".join(out)
    # bare value (lenient): strip an inline comment
    return rhs.split("#", 1)[0].strip().strip('"')


def _escape(value: str) -> str:
    # Must encode ALL control chars: TOML forbids them raw inside strings, so
    # a stray BEL/ESC (or newline) would make the file unreadable to tomllib
    # (3.11+) while the 3.9 fallback silently mangles it.
    named = {"\\": "\\\\", '"': '\\"', "\n": "\\n", "\t": "\\t", "\r": "\\r"}
    out = []
    for ch in value:
        if ch in named:
            out.append(named[ch])
        elif ord(ch) < 0x20 or ord(ch) == 0x7f:
            out.append(f"\\u{ord(ch):04X}")
        else:
            out.append(ch)
    return "".join(out)


def _dump_toml(data: dict) -> str:
    chunks = []
    for name in sorted(data):
        chunks.append(f"[{name}]")
        for key in data[name]:
            chunks.append(f'{key} = "{_escape(str(data[name][key]))}"')
        chunks.append("")  # blank line between tables
    return "\n".join(chunks).rstrip("\n") + "\n"


def load_registry() -> dict:
    path = registry_path()
    if not path.exists():
        return {}
    text = path.read_text(encoding="utf-8")
    try:
        data = _tomllib.loads(text) if _tomllib is not None else _parse_toml(text)
    except Exception as e:
        # A corrupt registry must fail loudly and cleanly — NOT return {}.
        # (An empty result would let the next save_registry() rewrite the file
        # and silently drop every other context.)
        die(f"could not parse {path}: {e} — fix or remove that file")
        raise SystemExit(1)
    # The registry is untrusted input (it may be hand-edited or synced). Drop any
    # table whose name isn't a safe context name, so a crafted key like
    # `[../../evil]` can never be resolved into a path outside the store.
    clean = {}
    for key, value in data.items():
        if not NAME_RE.match(key):
            print(f"cloudctx: warning: ignoring invalid context name {key!r} "
                  f"in {path}", file=sys.stderr)
            continue
        if not isinstance(value, dict):
            print(f"cloudctx: warning: ignoring non-table entry {key!r} "
                  f"in {path}", file=sys.stderr)
            continue
        # Values reach shquote()/encode() and az argv, so only strings are
        # usable. Drop (never coerce) anything else: a hand-edited
        # `azure_subscription = true` must not become the subscription "True".
        entry = {}
        for k, v in value.items():
            if isinstance(v, str):
                entry[k] = v
            else:
                print(f"cloudctx: warning: ignoring non-string value for "
                      f"{k!r} in [{key}] in {path}", file=sys.stderr)
        clean[key] = entry
    return clean


def save_registry(data: dict) -> None:
    root = REGISTRY_ROOT()
    root.mkdir(parents=True, exist_ok=True)
    _chmod(root, 0o700)  # registry root holds credential stores: owner-only
    path = registry_path()
    tmp = path.with_suffix(".toml.tmp")
    tmp.write_text(_dump_toml(data), encoding="utf-8")
    _chmod(tmp, 0o600)   # contexts.toml holds tenant/account identifiers
    os.replace(tmp, path)  # atomic on POSIX


# --------------------------------------------------------------------------
# Env emission — the isolation core. `_env` prints shell statements that the
# sourced `ctx` shim eval's into the parent shell. Values are single-quote
# escaped because the registry is untrusted input to that eval.
# --------------------------------------------------------------------------
CLEARABLE_VARS = [
    "CLOUDCTX_CONTEXT", "CLOUDCTX_AZURE_LABEL", "AZURE_CONFIG_DIR",
    "AWS_CONFIG_FILE", "AWS_SHARED_CREDENTIALS_FILE", "AWS_PROFILE",
]


def shquote(s: str) -> str:
    """POSIX-safe single-quoting: wrap in '...' and escape embedded ' as '\\''."""
    return "'" + s.replace("'", "'\\''") + "'"


def env_dict(name: str) -> dict:
    """The environment a context exports, as a plain dict (shared by _env and exec)."""
    entry = load_registry()[name]
    env = {
        "CLOUDCTX_CONTEXT": name,
        # Always redirect Azure to the isolated store — even an AWS-only context
        # should never fall back to the global ~/.azure.
        "AZURE_CONFIG_DIR": str(azure_dir(name).resolve()),
    }
    if entry.get("azure_subscription"):
        env["CLOUDCTX_AZURE_LABEL"] = entry["azure_subscription"]
    # AWS vars only when the context actually defines AWS fields (v1 = opt-in).
    if any(entry.get(f) for f in AWS_FIELDS):
        env["AWS_CONFIG_FILE"] = str(aws_config(name).resolve())
        env["AWS_SHARED_CREDENTIALS_FILE"] = str(aws_credentials(name).resolve())
        env["AWS_PROFILE"] = entry.get("aws_profile") or name
    return env


def env_lines(name: str) -> list:
    env = env_dict(name)
    lines = [f"export {k}={shquote(v)}" for k, v in env.items()]
    # Explicitly unset every managed var this context does NOT set, so a single
    # eval fully *replaces* the previous context (no stale AWS_*/label bleed).
    lines += [f"unset {var}" for var in CLEARABLE_VARS if var not in env]
    return lines


def cmd_env(args) -> int:
    if args.clear:
        print("\n".join(f"unset {var}" for var in CLEARABLE_VARS))
        return 0
    if not args.name:
        return die("usage: cloudctx _env <name> | --clear")
    if args.name not in load_registry():
        return die(f"unknown context {args.name!r}")
    print("\n".join(env_lines(args.name)))
    return 0


# --------------------------------------------------------------------------
# Color helpers. A single `color = "#rrggbb"` registry field feeds two distinct
# encodings: packed hex for the iTerm2 SetColors escape code (here), and
# float components 0.0-1.0 for Dynamic Profiles JSON (build_profiles, later).
# --------------------------------------------------------------------------
def hex_to_rgb255(color: str):
    c = color.lstrip("#").strip()
    if len(c) == 3:
        c = "".join(ch * 2 for ch in c)
    if len(c) != 6 or any(ch not in "0123456789abcdefABCDEF" for ch in c):
        raise ValueError(f"bad color {color!r}")
    return int(c[0:2], 16), int(c[2:4], 16), int(c[4:6], 16)


def rgb_floats(color: str):
    r, g, b = hex_to_rgb255(color)
    return r / 255, g / 255, b / 255


def _hex6(color: str) -> str:
    r, g, b = hex_to_rgb255(color)
    return f"{r:02x}{g:02x}{b:02x}"


# --------------------------------------------------------------------------
# Decorate emission — raw iTerm2 escape sequences. `cloudctx use` runs this WITHOUT
# command substitution so the bytes reach the controlling tty and render.
# Verified sequences: badge needs base64; tab color is packed hex (no '#').
# --------------------------------------------------------------------------
def _badge_seq(text: str) -> str:
    b64 = base64.b64encode(text.encode("utf-8")).decode("ascii")
    return f"{ESC}]1337;SetBadgeFormat={b64}{BEL}"


def _strip_controls(text: str) -> str:
    # Drop C0 (<0x20), DEL (0x7f) and C1 (0x80-0x9f) controls so a crafted
    # display can't terminate the OSC early or start an 8-bit control sequence
    # (the badge is base64-encoded, so it's already safe).
    return "".join(ch for ch in text
                   if ord(ch) >= 0x20 and not (0x7f <= ord(ch) <= 0x9f))


def _title_seq(text: str) -> str:
    return f"{ESC}]0;{_strip_controls(text)}{BEL}"  # OSC 0 sets tab+window title


def _tabcolor_seq(hex6: str) -> str:
    return f"{ESC}]1337;SetColors=tab={hex6}{BEL}"


def decorate_bytes(name: str) -> str:
    entry = load_registry()[name]
    display = entry.get("display") or name
    out = _badge_seq(display) + _title_seq(display)
    color = entry.get("color")
    if color:
        try:
            out += _tabcolor_seq(_hex6(color))
        except ValueError:
            pass  # malformed color: skip the tab-color sequence, don't crash
    return out


def decorate_clear() -> str:
    return (f"{ESC}]1337;SetBadgeFormat={BEL}"          # empty badge payload
            f"{ESC}]1337;SetColors=tab=default{BEL}")    # documented reset


def cmd_decorate(args) -> int:
    if args.clear:
        sys.stdout.write(decorate_clear())
        return 0
    if not args.name:
        return die("usage: cloudctx _decorate <name> | --clear")
    if args.name not in load_registry():
        return die(f"unknown context {args.name!r}")
    sys.stdout.write(decorate_bytes(args.name))
    return 0


# --------------------------------------------------------------------------
# Auth. v1 automates Azure only; AWS prints a guided stub (the per-context
# store and env exports already exist, so AWS becomes functional once the AWS
# CLI is installed and a login populates the files).
# --------------------------------------------------------------------------
AWS_STUB = (
    "AWS auth is not yet automated in this version. Once the AWS CLI is "
    "installed, point AWS_CONFIG_FILE at {cfg} and run `aws sso login`, or write "
    "static keys into {cred}. See the README for details."
)


def azure_login_cmds(entry, device_code=False):
    login = ["az", "login"]
    if entry.get("azure_tenant"):
        login += ["--tenant", entry["azure_tenant"]]
    if device_code:
        login += ["--use-device-code"]
    cmds = [login]
    if entry.get("azure_subscription"):
        cmds.append(["az", "account", "set", "--subscription", entry["azure_subscription"]])
    return cmds


GUID_RE = re.compile(r"^[0-9a-fA-F]{8}-(?:[0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$")


def _verify_azure_login(name, entry, env) -> None:
    """Post-login check: print the identity we actually landed on, and warn
    loudly if it's a different tenant than the registry pins. Compared only
    when both sides are GUID-shaped — a domain-form azure_tenant can't be
    matched against the landed tenantId without a directory lookup."""
    status, d = _probe_json(["az", "account", "show", "-o", "json"], env=env)
    if status != "ok" or not isinstance(d, dict):
        return  # login itself succeeded; verification is best-effort
    print(f"logged in: {d.get('name')} ({d.get('id')})  tenant={d.get('tenantId')}")
    want = entry.get("azure_tenant") or ""
    got = d.get("tenantId") or ""
    if GUID_RE.match(want) and GUID_RE.match(got) and want.lower() != got.lower():
        print(f"cloudctx: WARNING — tenant MISMATCH: context {name!r} pins "
              f"tenant {want} but this login landed in {got}. You may be "
              f"authenticated against the wrong customer.", file=sys.stderr)


def cmd_login(args) -> int:
    name = args.name
    registry = load_registry()
    if name not in registry:
        return die(f"unknown context {name!r}")
    entry = registry[name]
    has_azure = any(entry.get(f) for f in AZURE_FIELDS)
    has_aws = any(entry.get(f) for f in AWS_FIELDS)
    do_azure = has_azure or not has_aws  # azure by default unless aws-only

    env = dict(os.environ)
    azconf = str(azure_dir(name).resolve())
    env["AZURE_CONFIG_DIR"] = azconf  # isolate tokens into the context store

    if do_azure:
        for vec in azure_login_cmds(entry, device_code=getattr(args, "device_code", False)):
            if getattr(args, "dry_run", False):
                print(f"AZURE_CONFIG_DIR={azconf} " + " ".join(vec))
            else:
                print("+ " + " ".join(vec))
                if subprocess.run(vec, env=env).returncode != 0:
                    return die(f"`{' '.join(vec)}` failed")
        if not getattr(args, "dry_run", False):
            _verify_azure_login(name, entry, env)
    if has_aws:
        print(AWS_STUB.format(cfg=aws_config(name), cred=aws_credentials(name)))
    return 0


# --------------------------------------------------------------------------
# exec + status
# --------------------------------------------------------------------------
def cmd_exec(args) -> int:
    name = args.name
    if name not in load_registry():
        return die(f"unknown context {name!r}")
    cmd = list(args.cmd or [])
    if cmd and cmd[0] == "--":
        cmd = cmd[1:]
    if not cmd:
        return die("usage: cloudctx exec <name> -- <command> [args...]")
    # Strip any managed vars inherited from the caller's shell before overlaying
    # this context's, so exec is fail-closed (no other context's AWS_* leaks in).
    env = {k: v for k, v in os.environ.items() if k not in CLEARABLE_VARS}
    env.update(env_dict(name))
    try:
        return subprocess.run(cmd, env=env).returncode
    except FileNotFoundError:
        return die(f"command not found: {cmd[0]}")


PROBE_TIMEOUT = 10.0  # seconds; a hung probe must not freeze the shell


def _probe_timeout() -> float:
    try:
        return float(os.environ.get("CLOUDCTX_PROBE_TIMEOUT", PROBE_TIMEOUT))
    except ValueError:
        return PROBE_TIMEOUT


def _probe_json(argv, timeout=None, env=None):
    """Run a read-only identity probe (az/aws). Returns (status, data):
    ("ok", parsed-json) on success, ("timeout", None) past the deadline,
    ("error", None) for any other failure. Never raises."""
    if timeout is None:
        timeout = _probe_timeout()
    try:
        r = subprocess.run(argv, capture_output=True, text=True,
                           timeout=timeout, env=env)
    except subprocess.TimeoutExpired:
        return "timeout", None
    except OSError:
        return "error", None
    if r.returncode != 0:
        return "error", None
    try:
        return "ok", json.loads(r.stdout)
    except ValueError:
        return "error", None


def cmd_status(args) -> int:
    print(f"context: {os.environ.get('CLOUDCTX_CONTEXT', '(none)')}")

    if shutil.which("az"):
        status, d = _probe_json(["az", "account", "show", "-o", "json"])
        if status == "ok" and isinstance(d, dict):
            user = (d.get("user") or {}).get("name")
            print(f"azure:   {d.get('name')} ({d.get('id')})  "
                  f"tenant={d.get('tenantId')}  user={user}")
        elif status == "ok":
            print("azure:   (could not parse `az account show`)")
        elif status == "timeout":
            print("azure:   (timed out — network/VPN down?)")
        else:
            print("azure:   not logged in (run: cloudctx login <name>)")
    else:
        print("azure:   az CLI not installed")

    if shutil.which("aws"):
        status, d = _probe_json(["aws", "sts", "get-caller-identity",
                                 "--output", "json"])
        if status == "ok" and isinstance(d, dict):
            print(f"aws:     account={d.get('Account')}  arn={d.get('Arn')}")
        elif status == "ok":
            print("aws:     (could not parse caller identity)")
        elif status == "timeout":
            print("aws:     (timed out — network/VPN down?)")
        else:
            print("aws:     not authenticated")
    else:
        print("aws:     not configured (aws CLI not installed)")
    return 0


# --------------------------------------------------------------------------
# Windowing — open a new iTerm2 window/tab already scoped to a context.
# iTerm2's AppleScript is frozen but stable; we drive it via osascript argv
# (no shell), escaping only the AppleScript string literal.
# --------------------------------------------------------------------------
def applescript_escape(s: str) -> str:
    return s.replace("\\", "\\\\").replace('"', '\\"')


def build_open_command(name: str, cd=None, claude=False) -> str:
    parts = [f"cloudctx use {name}"]
    if cd:
        parts.append(f"cd {shquote(cd)}")
    if claude:
        parts.append("claude")
    return " && ".join(parts)


def open_osascript_argv(command: str, tab=False):
    esc = applescript_escape(command)
    if tab:
        body = [
            'tell application "iTerm2"',
            'tell current window',
            'set _t to (create tab with default profile)',
            'end tell',
            'tell current session of current window',
            f'write text "{esc}"',
            'end tell',
            'end tell',
        ]
    else:
        body = [
            'tell application "iTerm2"',
            'set _w to (create window with default profile)',
            'tell current session of _w',
            f'write text "{esc}"',
            'end tell',
            'end tell',
        ]
    argv = ["osascript"]
    for line in body:
        argv += ["-e", line]
    return argv


def cmd_open(args) -> int:
    if args.name not in load_registry():
        return die(f"unknown context {args.name!r}")
    command = build_open_command(args.name, cd=getattr(args, "cd", None),
                                 claude=getattr(args, "claude", False))
    argv = open_osascript_argv(command, tab=getattr(args, "tab", False))
    if getattr(args, "dry_run", False):
        print("\n".join(argv))
        return 0
    if not shutil.which("osascript"):
        return die("osascript not found — `cloudctx open` needs macOS + iTerm2")
    return subprocess.run(argv).returncode


def cmd_claude(args) -> int:
    return cmd_open(argparse.Namespace(
        name=args.name, cd=args.path, claude=True,
        tab=getattr(args, "tab", False), dry_run=getattr(args, "dry_run", False)))


# --------------------------------------------------------------------------
# iTerm2 Dynamic Profiles — one profile per context in the profile menu. Uses
# "Initial Text" (keeps an interactive shell, unlike "Custom Command"), a stable
# Guid, and the Tab Color object whose components are floats 0.0-1.0.
# --------------------------------------------------------------------------
def profiles_path() -> Path:
    override = os.environ.get("CLOUDCTX_PROFILES")
    if override:
        return Path(override)
    return (Path.home() / "Library" / "Application Support" / "iTerm2"
            / "DynamicProfiles" / "cloudctx.json")


def build_profiles(registry: dict) -> dict:
    profiles = []
    for name in sorted(registry):
        entry = registry[name]
        display = entry.get("display") or name
        prof = {
            "Name": f"{display} (ctx)",
            "Guid": f"cloudctx-{name}",  # stable across regenerations
            "Initial Text": f"cloudctx use {name}",
            "Custom Command": "No",
            "Command": "",
        }
        color = entry.get("color")
        if color:
            try:
                r, g, b = rgb_floats(color)
                prof["Use Tab Color"] = True
                prof["Tab Color"] = {
                    "Red Component": r, "Green Component": g, "Blue Component": b,
                    "Alpha Component": 1, "Color Space": "sRGB",
                }
            except ValueError:
                pass  # malformed color: skip tab color, keep the profile
        profiles.append(prof)
    return {"Profiles": profiles}


def write_profiles() -> Path:
    path = profiles_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(build_profiles(load_registry()), indent=2),
                    encoding="utf-8")
    return path


def cmd_gen_profiles(args) -> int:
    path = write_profiles()
    n = len(build_profiles(load_registry())["Profiles"])
    print(f"wrote {n} profile(s) to {path}")
    return 0


# --------------------------------------------------------------------------
# install — print (or write) the shell-rc line that sources the shim.
# --------------------------------------------------------------------------
def script_dir() -> Path:
    return Path(__file__).resolve().parent


def cmd_install(args) -> int:
    requested = args.shell or os.path.basename(os.environ.get("SHELL", "zsh"))
    shell = "bash" if "bash" in requested else "zsh"
    shim = script_dir() / "shell" / f"cloudctx.{shell}"
    rc = Path.home() / (".bashrc" if shell == "bash" else ".zshrc")
    line = f"source {shim}"
    if args.write:
        existing = rc.read_text(encoding="utf-8") if rc.exists() else ""
        if line in existing:
            print(f"already installed in {rc} — nothing to do.")
            return 0
        with open(rc, "a", encoding="utf-8") as f:
            f.write(f"\n# cloudctx\n{line}\n")
        print(f"appended to {rc}:\n  {line}\nOpen a new shell to activate.")
    else:
        print(f"# add to {rc}:")
        print(line)
        print(f"# and make sure `cloudctx` is on PATH (it lives at {script_dir() / 'cloudctx'})")
        print("# re-run with --write to append the source line automatically.")
    return 0


# --------------------------------------------------------------------------
# self-update — the install is a git clone (binary symlinked out of it), so
# git is the update channel and vX.Y.Z tags are the versioning. --check is
# passive and explicit-only: no command ever phones home on its own.
# --------------------------------------------------------------------------
TAG_RE = re.compile(r"refs/tags/v?(\d+)\.(\d+)\.(\d+)$")


def _git(install_dir, *args, timeout=30):
    """Run git in the install dir; None on timeout/missing git (never raise)."""
    try:
        return subprocess.run(["git", "-C", str(install_dir), *args],
                              capture_output=True, text=True, timeout=timeout)
    except (subprocess.TimeoutExpired, OSError):
        return None


def _latest_remote_version(install_dir):
    """Highest vX.Y.Z tag on origin, as an int tuple — or None if unknowable."""
    r = _git(install_dir, "ls-remote", "--tags", "origin", timeout=20)
    if r is None or r.returncode != 0:
        return None
    best = None
    for line in r.stdout.splitlines():
        m = TAG_RE.search(line.strip())
        if m:
            v = tuple(int(x) for x in m.groups())
            if best is None or v > best:
                best = v
    return best


def cmd_self_update(args) -> int:
    install = script_dir()
    if not (install / ".git").exists():
        return die(f"{install} is not a git clone — update it the same way "
                   f"it was installed")

    if args.check:
        latest = _latest_remote_version(install)
        if latest is None:
            return die("could not read tags from origin (offline? no tags?)")
        latest_s = ".".join(map(str, latest))
        current = tuple(int(x) for x in __version__.split("."))
        if latest > current:
            print(f"update available: {__version__} -> {latest_s} "
                  f"(run: cloudctx self-update)")
        else:
            print(f"up to date: {__version__} (latest tag: v{latest_s})")
        return 0

    r = _git(install, "status", "--porcelain")
    if r is None or r.returncode != 0:
        return die(f"could not run git in {install}")
    if r.stdout.strip():
        return die(f"local changes in {install} — commit or stash them first; "
                   f"self-update never discards your edits")
    before = (_git(install, "rev-parse", "HEAD") or r).stdout.strip()
    pull = _git(install, "pull", "--ff-only", timeout=120)
    if pull is None or pull.returncode != 0:
        detail = pull.stderr.strip() if pull else "timed out"
        return die(f"git pull --ff-only failed: {detail}")
    after = (_git(install, "rev-parse", "HEAD") or pull).stdout.strip()
    if before == after:
        print(f"already up to date ({__version__})")
        return 0

    # Ask the NEW code for its version and let IT regenerate the iTerm2
    # profiles — this running process still has the old logic in memory.
    binpath = install / "cloudctx"
    new_version = "?"
    r = subprocess.run([sys.executable, str(binpath), "--version"],
                       capture_output=True, text=True)
    if r.returncode == 0:
        new_version = r.stdout.strip().replace("cloudctx ", "")
    subprocess.run([sys.executable, str(binpath), "gen-profiles"],
                   capture_output=True, text=True)  # tolerated on non-mac

    print(f"updated: {__version__} -> {new_version} "
          f"({before[:7]} -> {after[:7]})")
    print("open a new shell (or re-source the shim) to finish.")
    return 0


# --------------------------------------------------------------------------
# use/clear stubs — the sourced shell function intercepts these before the
# binary ever sees them (a child process can't export into its parent). If
# they reach us, the shim isn't loaded; explain instead of an argparse error.
# --------------------------------------------------------------------------
def cmd_use_stub(args) -> int:
    return die("`cloudctx use`/`cloudctx clear` need the sourced shell "
               "function, which isn't loaded in this shell. Run "
               "`cloudctx install --write` and open a new shell.")


# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="cloudctx", description=__doc__.splitlines()[0])
    p.add_argument("--version", action="version",
                   version=f"cloudctx {__version__}")
    sub = p.add_subparsers(dest="command", required=True)

    p_list = sub.add_parser("list", help="list contexts; mark the active one")
    p_list.add_argument("-v", "--verbose", action="store_true",
                        help="show display/azure/aws columns")
    p_list.set_defaults(func=cmd_list)

    p_show = sub.add_parser("show", help="show a context's registry entry + store paths")
    p_show.add_argument("name")
    p_show.set_defaults(func=cmd_show)

    p_names = sub.add_parser("_names", help="(internal) bare context names, for completion")
    p_names.set_defaults(func=cmd_names)

    p_del = sub.add_parser("delete", help="delete a context (registry entry + credential store)")
    p_del.add_argument("name")
    p_del.add_argument("--force", action="store_true",
                       help="skip the confirmation prompt")
    p_del.add_argument("--keep-store", dest="keep_store", action="store_true",
                       help="remove only the registry entry; keep ~/.cloudctx/<name>/")
    p_del.set_defaults(func=cmd_delete)

    # Intercepted by the sourced shell function; stubs for shim-less shells.
    p_use = sub.add_parser("use", help="select a context in this shell (needs the sourced shim)")
    p_use.add_argument("name", nargs="?")
    p_use.set_defaults(func=cmd_use_stub)
    p_clear = sub.add_parser("clear", help="deselect the context (needs the sourced shim)")
    p_clear.set_defaults(func=cmd_use_stub)

    p_new = sub.add_parser("new", help="scaffold a context + registry entry")
    p_new.add_argument("name")
    p_new.add_argument("--display", help="human-readable label")
    p_new.add_argument("--color", help="iTerm2 tab/badge color, e.g. #c0392b")
    p_new.add_argument("--azure-tenant", dest="azure_tenant")
    p_new.add_argument("--azure-subscription", dest="azure_subscription")
    p_new.add_argument("--aws-sso-start-url", dest="aws_sso_start_url")
    p_new.add_argument("--aws-sso-region", dest="aws_sso_region")
    p_new.add_argument("--aws-account-id", dest="aws_account_id")
    p_new.add_argument("--aws-role", dest="aws_role")
    p_new.add_argument("--aws-profile", dest="aws_profile")
    p_new.add_argument("--device-code", action="store_true",
                       help="use Azure device-code login flow (headless)")
    p_new.add_argument("--no-login", action="store_true",
                       help="scaffold only; skip first-time authentication")
    p_new.add_argument("--no-profiles", action="store_true",
                       help="don't regenerate the iTerm2 dynamic profiles")
    p_new.set_defaults(func=cmd_new)

    # Internal: consumed by the sourced shell shim, not meant for direct use.
    p_env = sub.add_parser("_env", help="(internal) emit shell export/unset lines")
    p_env.add_argument("name", nargs="?")
    p_env.add_argument("--clear", action="store_true")
    p_env.set_defaults(func=cmd_env)

    p_dec = sub.add_parser("_decorate", help="(internal) emit iTerm2 escape sequences")
    p_dec.add_argument("name", nargs="?")
    p_dec.add_argument("--clear", action="store_true")
    p_dec.set_defaults(func=cmd_decorate)

    p_exec = sub.add_parser("exec", help="run one command in a context (shell unchanged)")
    p_exec.add_argument("name")
    p_exec.add_argument("cmd", nargs=argparse.REMAINDER,
                        help="-- <command> [args...]")
    p_exec.set_defaults(func=cmd_exec)

    p_status = sub.add_parser("status", aliases=["whoami"],
                              help="show the real identity for this shell")
    p_status.set_defaults(func=cmd_status)

    p_login = sub.add_parser("login", help="(re)authenticate a context into its store")
    p_login.add_argument("name")
    p_login.add_argument("--device-code", action="store_true",
                         help="use Azure device-code login flow (headless)")
    p_login.add_argument("--dry-run", action="store_true",
                         help="print the auth commands instead of running them")
    p_login.set_defaults(func=cmd_login)

    p_open = sub.add_parser("open", help="open a new iTerm2 window/tab scoped to a context")
    p_open.add_argument("name")
    p_open.add_argument("--cd", help="cd to this path in the new session")
    p_open.add_argument("--tab", action="store_true", help="new tab instead of window")
    p_open.add_argument("--claude", action="store_true", help="also run `claude`")
    p_open.add_argument("--dry-run", action="store_true",
                        help="print the osascript argv instead of running it")
    p_open.set_defaults(func=cmd_open)

    p_claude = sub.add_parser("claude", help="open a scoped window, cd, and run claude")
    p_claude.add_argument("name")
    p_claude.add_argument("path", nargs="?", help="project path to cd into")
    p_claude.add_argument("--tab", action="store_true", help="new tab instead of window")
    p_claude.add_argument("--dry-run", action="store_true",
                          help="print the osascript argv instead of running it")
    p_claude.set_defaults(func=cmd_claude)

    p_gen = sub.add_parser("gen-profiles",
                           help="regenerate the iTerm2 dynamic profiles file")
    p_gen.set_defaults(func=cmd_gen_profiles)

    p_up = sub.add_parser("self-update",
                          help="update the install (git pull) + regen profiles")
    p_up.add_argument("--check", action="store_true",
                      help="only report whether a newer tag exists on origin")
    p_up.set_defaults(func=cmd_self_update)

    p_install = sub.add_parser("install", help="print/write the shell-rc source line")
    p_install.add_argument("--shell", choices=["zsh", "bash"],
                           help="target shell (default: from $SHELL)")
    p_install.add_argument("--write", action="store_true",
                           help="append the source line to your rc file")
    p_install.set_defaults(func=cmd_install)

    return p


def main(argv) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
